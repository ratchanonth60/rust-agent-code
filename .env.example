# Required: API key for the selected provider
API_KEY=your-api-key-here

# Provider: gemini, openai, openrouter (default: gemini)
PROVIDER=gemini

# Model name (default: gemini-3-flash-preview)
MODEL=gemini-3-flash-preview

# Optional: override API base URL for custom OpenAI-compatible endpoints
# API_BASE=https://custom-endpoint.example.com/v1
